---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---

<Layout title="Blog — VicsoTheme" description="Writing about mobile development, language learning apps, EdTech, and building as an indie developer.">
  <style>
    .orb { position: fixed; border-radius: 50%; filter: blur(120px); pointer-events: none; z-index: 0; opacity: 0.11; }
    .orb-1 { width: 500px; height: 500px; background: #22c55e; top: -100px; left: -100px; }
    .orb-2 { width: 400px; height: 400px; background: #3b82f6; bottom: -100px; right: -100px; }

    .page-header { padding: 80px 0 64px; }
    .back-link { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 12px; color: var(--muted); text-decoration: none; letter-spacing: 0.04em; margin-bottom: 32px; transition: color 0.2s; }
    .back-link:hover { color: var(--text); }
    .page-title { font-size: clamp(32px, 5vw, 52px); font-weight: 300; letter-spacing: -0.03em; color: #fff; line-height: 1.1; margin-bottom: 14px; }
    .page-title em { font-style: normal; color: var(--accent-b) }
    .page-sub { font-size: 16px; color: var(--muted); font-weight: 300; line-height: 1.6; max-width: 440px; }

    .empty-state { border: 1px dashed var(--border); border-radius: 16px; padding: 80px 40px; text-align: center; margin-bottom: 96px; }
    .empty-icon { font-size: 40px; margin-bottom: 16px; }
    .empty-title { font-size: 18px; font-weight: 500; color: #fff; margin-bottom: 8px; }
    .empty-sub { font-size: 14px; color: var(--muted); line-height: 1.6; }

    .posts-list { display: flex; flex-direction: column; gap: 2px; margin-bottom: 96px; }
    .post-row { display: grid; grid-template-columns: 140px 1fr auto auto; align-items: center; gap: 24px; padding: 20px 12px; border-bottom: 1px solid var(--border); text-decoration: none; color: inherit; transition: background 0.2s; border-radius: 8px; }
    .post-row:hover { background: rgba(255,255,255,0.03); }
    .post-row:hover .post-title { color: #fff; }
    .post-row:hover .post-arrow { opacity: 1; }
    .post-date { font-family: var(--mono); font-size: 12px; color: var(--muted); white-space: nowrap; }
    .post-info { min-width: 0; }
    .post-title { font-size: 16px; font-weight: 500; color: rgba(255,255,255,0.85); margin-bottom: 4px; transition: color 0.2s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .post-desc { font-size: 13px; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .post-tags { display: flex; gap: 6px; flex-shrink: 0; }
    .post-tag { font-family: var(--mono); font-size: 10px; padding: 3px 8px; border-radius: 5px; border: 1px solid var(--border); color: var(--muted); background: rgba(255,255,255,0.03); }
    .post-arrow { color: var(--muted); opacity: 0; transition: opacity 0.2s; flex-shrink: 0; }

    @media (max-width: 640px) {
      .post-row { grid-template-columns: 1fr; gap: 6px; }
      .post-tags, .post-arrow, .post-date { display: none; }
    }
  </style>

  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>

  <div class="page-header">
    <div class="wrap">
      <a href="/" class="back-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="15 18 9 12 15 6"/></svg>
        Back to home
      </a>
      <h1 class="page-title">The <em>Blog</em></h1>
      <p class="page-sub">Writing about indie dev, language learning apps, EdTech, and building things solo.</p>
    </div>
  </div>

  <div class="wrap">
    {posts.length === 0 ? (
      <div class="empty-state reveal">
        <div class="empty-icon">✍️</div>
        <div class="empty-title">First post coming soon</div>
        <div class="empty-sub">Writing about mobile dev, language learning,<br />spaced repetition, and shipping apps solo.</div>
      </div>
    ) : (
      <div class="posts-list">
        {posts.map((post, i) => (
          <a class="post-row reveal" style={`transition-delay:${i * 0.05}s`} href={`/blog/${post.id}`}>
            <span class="post-date">{formatDate(post.data.date)}</span>
            <div class="post-info">
              <div class="post-title">{post.data.title}</div>
              <div class="post-desc">{post.data.description}</div>
            </div>
            <div class="post-tags">
              {(post.data.tags ?? []).slice(0, 2).map(tag => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
            <svg class="post-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>