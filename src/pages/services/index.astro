---
import Layout from '../../layouts/Layout.astro';

const title = "AI Product Engineering Services | Viktor Sokoliuk";
const description = "AI-augmented product engineering for SaaS platforms, mobile products, CMS architecture, EdTech systems, and technical strategy.";

const servicePillars = [
  {
    number: "01",
    title: "AI Product Engineering",
    slug: "ai-product-engineering",
    kicker: "AI Systems • SaaS • Automation",
    description:
      "AI-powered products, MVPs, LLM integrations, internal tools, agents, and workflow automation systems built around real product value.",
    capabilities: ["AI MVPs", "LLM integrations", "AI SaaS", "AI agents", "workflow automation"],
    stack: ["OpenAI", "Claude", "Next.js", "Python", "PostgreSQL"],
  },
  {
    number: "02",
    title: "SaaS Platform Engineering",
    slug: "saas-platform-engineering",
    kicker: "Dashboards • Platforms • Product Systems",
    description:
      "Scalable web platforms, dashboards, admin systems, and product infrastructure for startups and growing digital products.",
    capabilities: ["Next.js apps", "dashboards", "admin systems", "platform architecture", "product infrastructure"],
    stack: ["Next.js", "TypeScript", "Django", "PostgreSQL", "Docker"],
  },
  {
    number: "03",
    title: "Mobile Product Engineering",
    slug: "mobile-product-engineering",
    kicker: "Flutter • PWA • Subscriptions",
    description:
      "Cross-platform mobile products with clean UX, subscription systems, app store readiness, and scalable backend architecture.",
    capabilities: ["Flutter apps", "PWAs", "subscription systems", "cross-platform products", "launch support"],
    stack: ["Flutter", "Firebase", "RevenueCat", "Google Play", "REST APIs"],
  },
  {
    number: "04",
    title: "CMS & Content Architecture",
    slug: "cms-content-architecture",
    kicker: "Strapi • Headless CMS • SEO Systems",
    description:
      "Structured content systems, headless CMS architecture, editorial workflows, high-performance WordPress systems, and SEO-ready platforms.",
    capabilities: ["Strapi", "headless CMS", "WordPress architecture", "SEO systems", "content workflows"],
    stack: ["Strapi", "WordPress", "Astro", "Next.js", "PostgreSQL"],
  },
  {
    number: "05",
    title: "EdTech & Learning Systems",
    slug: "edtech-learning-systems",
    kicker: "SRS • Language Learning • Retention",
    description:
      "Learning products, spaced repetition systems, gamified educational flows, language-learning apps, and retention-focused UX.",
    capabilities: ["spaced repetition", "language learning", "gamification", "learning UX", "retention systems"],
    stack: ["Flutter", "Python", "Firebase", "AI APIs", "Analytics"],
  },
  {
    number: "06",
    title: "Technical Strategy & Optimization",
    slug: "technical-strategy-optimization",
    kicker: "Architecture • Performance • Product Direction",
    description:
      "Technical audits, performance optimization, UX review, architecture planning, monetization systems, and product strategy support.",
    capabilities: ["performance", "architecture", "UX audits", "monetization", "product strategy"],
    stack: ["Lighthouse", "SEO", "Analytics", "CI/CD", "Infrastructure"],
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://vicsotheme.com" },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://vicsotheme.com/services" },
  ]
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "AI-era product engineering services",
  "itemListElement": servicePillars.map((service, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": service.title,
    "url": `https://vicsotheme.com/services/${service.slug}`
  }))
};
---

<Layout title={title} description={description}>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  </Fragment>

  <style>
    /* Services overview — aligned with the existing vicsotheme design system.
       Uses global tokens from Layout.astro:
       --bg, --bg-card, --bg-hover, --border, --border-hi,
       --text, --heading, --muted, --muted-hi,
       --accent-d, --accent-b, --mono, --sans.
    */

    .services-page {
      position: relative;
      overflow: hidden;
    }

    .services-page > * {
      position: relative;
      z-index: 1;
    }

    /* ── Hero ── */
    .services-hero {
      padding: 80px 0 64px;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.04em;
      margin-bottom: 40px;
      transition: color 0.2s;
    }

    .back-link:hover {
      color: var(--text);
    }

    .hero-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 340px;
      gap: 48px;
      align-items: end;
    }

    .hero-eyebrow,
    .section-label,
    .card-kicker,
    .proof-label {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .hero-eyebrow {
      color: var(--accent-b);
      margin-bottom: 16px;
    }

    .hero-title {
      max-width: 760px;
      font-size: clamp(38px, 5.8vw, 68px);
      font-weight: 300;
      line-height: 1.08;
      letter-spacing: -0.04em;
      color: var(--heading);
      margin-bottom: 22px;
    }

    .hero-desc {
      max-width: 620px;
      font-size: 18px;
      line-height: 1.7;
      color: var(--muted);
      font-weight: 300;
    }

    .hero-panel {
      border: 1px solid var(--border);
      background: var(--bg-card);
      border-radius: 20px;
      padding: 26px;
      overflow: hidden;
      position: relative;
    }

    .hero-panel::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent-d), transparent);
      opacity: 0.35;
    }

    .hero-panel-title {
      color: var(--heading);
      font-size: 17px;
      line-height: 1.35;
      font-weight: 500;
      margin-bottom: 20px;
    }

    .hero-panel-list {
      display: grid;
      gap: 14px;
    }

    .hero-panel-item {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      padding-bottom: 14px;
      border-bottom: 1px solid var(--border);
      color: var(--muted);
      font-size: 13px;
      line-height: 1.55;
    }

    .hero-panel-item:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .hero-panel-item span:first-child {
      color: var(--heading);
      font-weight: 500;
      flex-shrink: 0;
    }

    /* ── Positioning strip ── */
    .positioning-strip {
      padding: 0 0 72px;
    }

    .strip-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border: 1px solid var(--border);
      border-radius: 20px;
      overflow: hidden;
      background: var(--bg-card);
    }

    .strip-item {
      padding: 26px;
      border-right: 1px solid var(--border);
    }

    .strip-item:last-child {
      border-right: 0;
    }

    .strip-item strong {
      display: block;
      color: var(--heading);
      font-size: 16px;
      font-weight: 500;
      margin-bottom: 8px;
    }

    .strip-item span {
      display: block;
      color: var(--muted);
      font-size: 14px;
      font-weight: 300;
      line-height: 1.65;
    }

    /* ── Services ── */
    .services-overview {
      padding: 0 0 96px;
    }

    .section-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 360px;
      gap: 40px;
      align-items: end;
      margin-bottom: 32px;
    }

    .section-label {
      color: var(--muted);
      margin-bottom: 16px;
    }

    .section-title {
      max-width: 760px;
      font-size: clamp(30px, 4vw, 48px);
      font-weight: 300;
      line-height: 1.14;
      letter-spacing: -0.035em;
      color: var(--heading);
    }

    .section-desc {
      color: var(--muted);
      line-height: 1.7;
      font-weight: 300;
      font-size: 15px;
    }

    .pillars-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .pillar-card {
      min-height: 360px;
      display: flex;
      flex-direction: column;
      border: 1px solid var(--border);
      border-radius: 20px;
      background: var(--bg-card);
      padding: 30px;
      text-decoration: none;
      overflow: hidden;
      position: relative;
      transition: border-color 0.25s, transform 0.25s, background 0.25s;
    }


    .pillar-card:hover {
      transform: translateY(-2px);
      border-color: var(--border-hi);
      background: var(--bg-hover);
    }

    .card-topline {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 34px;
      color: var(--muted);
      position: relative;
      z-index: 1;
    }

    .card-number {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.1em;
    }

    .card-arrow {
      font-size: 17px;
      transition: transform 0.22s, color 0.22s;
    }

    .pillar-card:hover .card-arrow {
      transform: translate(3px, -3px);
      color: var(--heading);
    }

    .card-kicker {
      color: var(--accent-d);
      margin-bottom: 14px;
      position: relative;
      z-index: 1;
    }

    .card-title {
      color: var(--heading);
      font-size: clamp(24px, 3vw, 34px);
      line-height: 1.1;
      letter-spacing: -0.035em;
      font-weight: 300;
      margin-bottom: 16px;
      max-width: 520px;
      position: relative;
      z-index: 1;
    }

    .card-desc {
      color: var(--muted);
      line-height: 1.7;
      font-size: 14px;
      font-weight: 300;
      max-width: 620px;
      position: relative;
      z-index: 1;
    }

    .capability-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 26px;
      position: relative;
      z-index: 1;
    }

    .capability-chip {
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 7px 10px;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 11px;
      line-height: 1;
      background: var(--bg-hover);
    }

    .stack-row {
      margin-top: auto;
      padding-top: 30px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      position: relative;
      z-index: 1;
    }

    .stack-item {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      color: var(--muted);
    }

    /* ── Proof ── */
    .proof-section {
      padding: 0 0 96px;
    }

    .proof-grid {
      display: grid;
      grid-template-columns: 0.82fr 1.18fr;
      gap: 16px;
    }

    .proof-card {
      border: 1px solid var(--border);
      border-radius: 20px;
      background: var(--bg-card);
      padding: 34px;
      overflow: hidden;
      position: relative;
    }

    .proof-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent-b), transparent);
      opacity: 0.22;
    }

    .proof-label {
      color: var(--muted);
      margin-bottom: 16px;
    }

    .proof-card h2 {
      color: var(--heading);
      font-size: clamp(28px, 3.6vw, 42px);
      line-height: 1.14;
      letter-spacing: -0.035em;
      font-weight: 300;
      margin-bottom: 18px;
    }

    .proof-card p {
      color: var(--muted);
      line-height: 1.7;
      font-weight: 300;
      font-size: 15px;
    }

    .proof-list {
      display: grid;
      gap: 16px;
    }

    .proof-list-item {
      display: grid;
      grid-template-columns: 150px 1fr;
      gap: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border);
    }

    .proof-list-item:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .proof-list-item strong {
      color: var(--heading);
      font-weight: 500;
      font-size: 14px;
      line-height: 1.4;
    }

    .proof-list-item span {
      color: var(--muted);
      line-height: 1.65;
      font-size: 14px;
      font-weight: 300;
    }

    /* ── CTA ── */
    .services-cta {
      padding: 0 0 96px;
    }

    .cta-box {
      border: 1px solid var(--border);
      border-radius: 20px;
      background: var(--bg-card);
      padding: 56px 48px;
      text-align: center;
      overflow: hidden;
      position: relative;
    }

    .cta-box > * {
      position: relative;
      z-index: 1;
    }

    .cta-box h2 {
      max-width: 720px;
      margin: 0 auto 18px;
      color: var(--heading);
      font-size: clamp(30px, 4vw, 44px);
      line-height: 1.15;
      letter-spacing: -0.035em;
      font-weight: 300;
    }

    .cta-box p {
      max-width: 580px;
      margin: 0 auto 32px;
      color: var(--muted);
      line-height: 1.7;
      font-weight: 300;
      font-size: 15px;
    }

    .btn-primary,
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 46px;
      border-radius: 10px;
      padding: 13px 24px;
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      font-family: var(--sans);
      transition: opacity 0.2s, background 0.2s, border-color 0.2s, transform 0.2s;
    }

    .btn-primary {
      background: var(--text);
      color: var(--bg);
      border: 1px solid transparent;
    }

    .btn-secondary {
      color: var(--text);
      background: var(--bg-hover);
      border: 1px solid var(--border);
    }

    .cta-actions {
      display: flex;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .btn-primary:hover,
    .btn-secondary:hover {
      opacity: 0.86;
      transform: translateY(-1px);
    }

    .btn-secondary:hover {
      background: var(--bg-card);
      border-color: var(--border-hi);
    }

    @media (max-width: 980px) {
      .hero-layout,
      .section-head,
      .proof-grid {
        grid-template-columns: 1fr;
      }

      .hero-panel {
        max-width: 520px;
      }

      .pillars-grid {
        grid-template-columns: 1fr;
      }

      .strip-grid {
        grid-template-columns: 1fr;
      }

      .strip-item {
        border-right: 0;
        border-bottom: 1px solid var(--border);
      }

      .strip-item:last-child {
        border-bottom: 0;
      }
    }

    @media (max-width: 620px) {
      .services-hero {
        padding: 56px 0 52px;
      }

      .back-link {
        margin-bottom: 32px;
      }

      .hero-title {
        font-size: clamp(36px, 11vw, 54px);
      }

      .hero-desc {
        font-size: 16px;
      }

      .hero-panel,
      .pillar-card,
      .proof-card,
      .cta-box {
        border-radius: 18px;
      }

      .pillar-card {
        min-height: auto;
        padding: 26px 24px;
      }

      .proof-list-item {
        grid-template-columns: 1fr;
        gap: 8px;
      }

      .cta-box {
        padding: 40px 24px;
      }

      .btn-primary,
      .btn-secondary {
        width: 100%;
      }
    }
  </style>

  <main class="services-page">
    <section class="services-hero">
      <div class="wrap">
        <a href="/" class="back-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="15 18 9 12 15 6"/></svg>
          Home
        </a>

        <div class="hero-layout">
          <div>
            <div class="hero-eyebrow">AI-augmented product engineering</div>

            <h1 class="hero-title">
              Senior engineering for AI-era digital products.
            </h1>

            <p class="hero-desc">
              I help founders and businesses build scalable AI-powered products, SaaS platforms, mobile apps,
              content systems, and learning products with a product-first engineering approach.
            </p>
          </div>

          <aside class="hero-panel" aria-label="Positioning summary">
            <div class="hero-panel-title">Not a generic service catalogue.</div>

            <div class="hero-panel-list">
              <div class="hero-panel-item">
                <span>Role</span>
                <span>AI-augmented product engineer</span>
              </div>
              <div class="hero-panel-item">
                <span>Focus</span>
                <span>Systems, products, UX, performance</span>
              </div>
              <div class="hero-panel-item">
                <span>Best fit</span>
                <span>Founders, SaaS, EdTech, content platforms</span>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="positioning-strip" aria-label="How I work">
      <div class="wrap">
        <div class="strip-grid">
          <div class="strip-item">
            <strong>Product-first</strong>
            <span>Technology is chosen around user value, business goals, and maintainable execution.</span>
          </div>

          <div class="strip-item">
            <strong>AI-augmented</strong>
            <span>Modern AI workflows speed up delivery without replacing architecture and product thinking.</span>
          </div>

          <div class="strip-item">
            <strong>Senior execution</strong>
            <span>One technical partner across UX, frontend, backend, CMS, mobile, launch, and optimization.</span>
          </div>
        </div>
      </div>
    </section>

    <section class="services-overview" id="services">
      <div class="wrap">
        <div class="section-head">
          <div>
            <div class="section-label">Core services</div>
            <h2 class="section-title">Six focused pillars instead of a noisy list of tasks.</h2>
          </div>

          <p class="section-desc">
            Each direction is structured around product outcomes, not isolated implementation tasks.
            This keeps the offer clear, premium, and relevant to the AI-driven market.
          </p>
        </div>

        <div class="pillars-grid">
          {servicePillars.map(service => (
            <a href={`/services/${service.slug}`} class="pillar-card">
              <div class="card-topline">
                <span class="card-number">{service.number}</span>
                <span class="card-arrow">↗</span>
              </div>

              <div class="card-kicker">{service.kicker}</div>

              <h3 class="card-title">{service.title}</h3>

              <p class="card-desc">{service.description}</p>

              <div class="capability-list" aria-label={`${service.title} capabilities`}>
                {service.capabilities.map(item => (
                  <span class="capability-chip">{item}</span>
                ))}
              </div>

              <div class="stack-row" aria-label={`${service.title} stack`}>
                {service.stack.map(item => (
                  <span class="stack-item">{item}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="proof-section">
      <div class="wrap">
        <div class="proof-grid">
          <article class="proof-card">
            <div class="proof-label">Positioning</div>
            <h2>Built like a technical partner, not a task vendor.</h2>
            <p>
              The goal is not to sell a long list of disconnected services. The goal is to help you
              make better technical decisions, ship faster, and build systems that can grow after launch.
            </p>
          </article>

          <article class="proof-card">
            <div class="proof-label">Why it works</div>

            <div class="proof-list">
              <div class="proof-list-item">
                <strong>AI-native delivery</strong>
                <span>AI-assisted workflows are used to accelerate research, prototyping, content systems, and engineering execution.</span>
              </div>

              <div class="proof-list-item">
                <strong>Product judgment</strong>
                <span>Every build decision is connected to usability, conversion, retention, scalability, and maintenance.</span>
              </div>

              <div class="proof-list-item">
                <strong>Full-stack ownership</strong>
                <span>Frontend, backend, CMS, mobile, infrastructure, SEO, performance, and launch can be handled as one system.</span>
              </div>

              <div class="proof-list-item">
                <strong>Real product experience</strong>
                <span>Experience with shipped mobile apps, language-learning systems, subscription flows, CMS platforms, and performance optimization.</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="services-cta">
      <div class="wrap">
        <div class="cta-box">
          <div class="section-label">Start with direction</div>

          <h2>Have a product idea or technical problem?</h2>

          <p>
            Let’s define what should be built, what should be simplified, and where AI can create real value before writing unnecessary code.
          </p>

          <div class="cta-actions">
            <a href="/contact" class="btn-primary">Discuss Your Project</a>
            <a href="/apps" class="btn-secondary">View Product Work</a>
          </div>
        </div>
      </div>
    </section>
  </main>

</Layout>