---
import Layout from '../../layouts/Layout.astro';
import ROICalculator from '../../components/ROICalculator.astro';
import { getCollection } from 'astro:content';
 
export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => !data.draft);
  return services.map(service => ({
    params: { slug: service.id },
    props: { service },
  }));
}
 
const { service } = Astro.props;
const { data } = service;
const accent = data.accent;

const allServices = await getCollection('services', ({ data }) => !data.draft);
const relatedServices = allServices
  .filter(s => s.id !== service.id && s.data.category === data.category)
  .slice(0, 3);
 
const pageUrl = `https://vicsotheme.com/services/${service.id}`;
 
// FAQPage schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": data.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};
 
// Service schema
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": data.title,
  "description": data.description,
  "url": pageUrl,
  "provider": {
    "@type": "Person",
    "name": "Viktor Sokoliuk",
    "url": "https://vicsotheme.com",
    "jobTitle": "Full Stack Developer",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Tallinn",
      "addressCountry": "EE"
    }
  },
  "areaServed": "Worldwide",
  "serviceType": data.category
};
 
// BreadcrumbList schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://vicsotheme.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Services",
      "item": "https://vicsotheme.com/services"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": data.title,
      "item": pageUrl
    }
  ]
};
---

<Layout title={data.title} description={data.description}>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <style>
    .orb { position: fixed; border-radius: 50%; filter: blur(140px); pointer-events: none; z-index: 0; opacity: 0.1; }
    .orb-1 { width: 600px; height: 600px; top: -150px; left: -150px; }
    .orb-2 { width: 400px; height: 400px; bottom: -100px; right: -100px; }

    /* ── Hero ── */
    .service-hero {
      padding: 80px 0 72px;
      position: relative;
      z-index: 1;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.04em;
      margin-bottom: 40px;
      transition: color 0.2s;
    }
    .back-link:hover { color: var(--text); }

    .hero-category {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent-color);
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .hero-title {
      font-size: clamp(36px, 5.5vw, 60px);
      font-weight: 300;
      color: var(--heading);
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin-bottom: 20px;
      white-space: pre-line;
    }

    .hero-desc {
      font-size: 18px;
      line-height: 1.7;
      color: var(--muted);
      font-weight: 300;
      max-width: 560px;
      margin-bottom: 36px;
    }

    .hero-meta {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
    }

    .meta-item {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .meta-label {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .meta-value {
      font-size: 18px;
      font-weight: 500;
      color: var(--heading);
    }

    .hero-cta {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 36px;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--text);
      color: var(--bg);
      border: none;
      border-radius: 10px;
      padding: 13px 24px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      transition: opacity 0.2s;
      font-family: var(--sans);
    }
    .btn-primary:hover { opacity: 0.85; }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--bg-hover);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 13px 24px;
      font-size: 14px;
      color: var(--text);
      text-decoration: none;
      font-weight: 400;
      transition: background 0.2s, border-color 0.2s;
    }
    .btn-secondary:hover { background: var(--bg-card); border-color: var(--border-hi); }

    /* ── Stack badges ── */
    .stack-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 28px;
    }
    .stack-badge {
      font-family: var(--mono);
      font-size: 14px;
      padding: 5px 12px;
      border-radius: 100px;
      border: 1px solid var(--border);
      color: var(--muted);
      background: var(--bg-card);
    }

    /* ── Section ── */
    .content-section { padding: 0 0 80px; position: relative; z-index: 1; }

    .section-label {
      font-family: var(--mono);
      font-size: 18px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 32px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ── Deliverables ── */
    .deliverables-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 16px;
    }

    .deliverable-card {
      border: 1px solid var(--border);
      border-radius: 16px;
      background: var(--bg-card);
      padding: 28px;
      position: relative;
      overflow: hidden;
      transition: border-color 0.3s, transform 0.3s;
    }
    .deliverable-card:hover { border-color: var(--border-hi); transform: translateY(-2px); }
    .deliverable-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent-color), transparent);
      opacity: 0.6;
    }

    .deliverable-icon { font-size: 28px; margin-bottom: 14px; display: block; }
    .deliverable-title { font-size: 15px; font-weight: 500; color: var(--heading); margin-bottom: 8px; }
    .deliverable-desc { font-size: 13px; color: var(--muted); line-height: 1.65; font-weight: 300; }

    /* ── Process ── */
    .process-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .process-step {
      display: grid;
      grid-template-columns: 48px 1fr;
      gap: 24px;
      padding: 28px 0;
      border-bottom: 1px solid var(--border);
      position: relative;
    }
    .process-step:last-child { border-bottom: none; }

    .step-num {
      font-family: var(--mono);
      font-size: 13px;
      font-weight: 500;
      color: var(--accent-color);
      padding-top: 3px;
    }

    .step-content {}
    .step-title { font-size: 17px; font-weight: 500; color: var(--heading); margin-bottom: 8px; }
    .step-desc { font-size: 14px; color: var(--muted); line-height: 1.7; font-weight: 300; }

    /* ── Case study ── */
    .case-card {
      border: 1px solid var(--border);
      border-radius: 20px;
      background: var(--bg-card);
      padding: 40px;
      position: relative;
      overflow: hidden;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 32px;
      align-items: center;
    }
    .case-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent-color), transparent);
      opacity: 0.5;
    }

    .case-tag {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent-color);
      margin-bottom: 12px;
    }
    .case-title { font-size: 22px; font-weight: 500; color: var(--heading); margin-bottom: 10px; letter-spacing: -0.01em; }
    .case-desc { font-size: 14px; color: var(--muted); line-height: 1.7; font-weight: 300; margin-bottom: 16px; }
    .case-result {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--accent-color);
      padding: 8px 14px;
      border-radius: 8px;
      border: 1px solid color-mix(in srgb, var(--accent-color) 25%, transparent);
      background: color-mix(in srgb, var(--accent-color) 6%, transparent);
      display: inline-block;
    }
    .case-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: var(--accent-color);
      text-decoration: none;
      margin-top: 16px;
      opacity: 0.8;
      transition: opacity 0.2s;
    }
    .case-link:hover { opacity: 1; }

    /* ── FAQ ── */
    .faq-list { display: flex; flex-direction: column; gap: 2px; }

    .faq-item {
      border-bottom: 1px solid var(--border);
    }

    .faq-question {
      width: 100%;
      background: none;
      border: none;
      padding: 20px 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      cursor: pointer;
      text-align: left;
      font-family: var(--sans);
      font-size: 15px;
      font-weight: 500;
      color: var(--heading);
      transition: color 0.2s;
    }
    .faq-question:hover { color: var(--accent-color); }

    .faq-icon {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: transform 0.3s, border-color 0.2s;
      color: var(--muted);
      font-size: 14px;
    }
    .faq-item.is-open .faq-icon { transform: rotate(45deg); border-color: var(--accent-color); color: var(--accent-color); }

    .faq-answer {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.75;
      font-weight: 300;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s ease, padding 0.35s ease;
    }
    .faq-item.is-open .faq-answer {
      max-height: 300px;
      padding-bottom: 20px;
    }

    /* ── CTA ── */
    .service-cta {
      border: 1px solid var(--border);
      border-radius: 20px;
      background: var(--bg-card);
      padding: 64px 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
      margin-bottom: 96px;
    }
    .service-cta::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent-color), transparent);
      opacity: 0.6;
    }
    .service-cta-glow {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }
    .cta-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 16px; }
    .cta-title { font-size: clamp(26px, 4vw, 38px); font-weight: 300; color: var(--heading); letter-spacing: -0.02em; margin-bottom: 12px; line-height: 1.2; }
    .cta-sub { font-size: 15px; color: var(--muted); max-width: 420px; margin: 0 auto 32px; line-height: 1.6; font-weight: 300; }

    /* ── Related Services ── */
    .related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 16px;
    }

    .related-card {
      border: 1px solid var(--border);
      border-radius: 16px;
      background: var(--bg-card);
      padding: 28px 28px 24px;
      text-decoration: none;
      display: block;
      position: relative;
      overflow: hidden;
      transition: border-color 0.3s, transform 0.3s;
    }
   
    .related-card:hover { border-color: var(--border-hi); transform: translateY(-2px); }

    .related-card-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 14px;
    }
    .related-card-icon { font-size: 26px; line-height: 1; }
    .related-card-arrow {
      color: var(--muted);
      font-size: 16px;
      transition: transform 0.2s, color 0.2s;
      line-height: 1;
    }
    .related-card:hover .related-card-arrow {
      transform: translate(3px, -3px);
      color: var(--card-accent, var(--accent-color));
    }

    .related-card-title {
      font-size: 15px;
      font-weight: 500;
      color: var(--heading);
      line-height: 1.3;
      margin-bottom: 10px;
      max-width: 190px;
    }
    .related-card-badge {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.06em;
      color: var(--muted);
      padding: 3px 10px;
      border-radius: 100px;
      border: 1px solid var(--border);
      display: inline-block;
    }

    /* ── Responsive ── */
    @media (max-width: 700px) {
      .service-hero { padding: 56px 0 48px; }
      .deliverables-grid { grid-template-columns: 1fr; }
      .process-step { grid-template-columns: 36px 1fr; gap: 16px; }
      .case-card { grid-template-columns: 1fr; }
      .service-cta { padding: 40px 24px; }
      .hero-meta { gap: 16px; }
    }
  </style>

  <!-- Accent color as CSS var -->
  <style define:vars={{ 'accent-color': accent }}></style>


  <!-- Hero -->
  <section class="service-hero">
    <div class="wrap">
      <a href="/services" class="back-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="15 18 9 12 15 6"/></svg>
        All services
      </a>

      <div class="hero-category">
        {data.category}
      </div>

      <h1 class="hero-title">{data.headline}</h1>
      <p class="hero-desc">{data.description}</p>

      <div class="hero-meta">
        <div class="meta-item">
          <span class="meta-label">Timeline</span>
          <span class="meta-value">{data.timeline}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Investment</span>
          <span class="meta-value">{data.priceRange}</span>
        </div>
      </div>

      <div class="stack-row">
        {data.stack.map(s => <span class="stack-badge">{s}</span>)}
      </div>

      <div class="hero-cta">
        <a href="/contact" class="btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          Get a free estimate
        </a>
        <a href="/apps" class="btn-secondary">View my work ↓</a>
      </div>
    </div>
  </section>

  <!-- Deliverables -->
  <section class="content-section">
    <div class="wrap">
      <div class="section-label">What you get</div>
      <div class="deliverables-grid">
        {data.deliverables.map(d => (
          <div class="deliverable-card reveal">
            <span class="deliverable-icon">{d.icon}</span>
            <div class="deliverable-title">{d.title}</div>
            <p class="deliverable-desc">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="content-section">
    <div class="wrap">
      <div class="section-label">How it works</div>
      <div class="process-list">
        {data.process.map((p, i) => (
          <div class="process-step reveal" style={`transition-delay: ${i * 0.08}s`}>
            <div class="step-num">0{p.step}</div>
            <div class="step-content">
              <div class="step-title">{p.title}</div>
              <p class="step-desc">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case Study -->
  {data.caseStudy && (
    <section class="content-section">
      <div class="wrap">
        <div class="section-label">Real example</div>
        <div class="case-card reveal">
          <div>
            <div class="case-tag">Case Study</div>
            <div class="case-title">{data.caseStudy.title}</div>
            <p class="case-desc">{data.caseStudy.desc}</p>
            <div class="case-result">{data.caseStudy.result}</div>
          </div>
          <div style="font-size: 64px; opacity: 0.15;">{data.icon}</div>
        </div>
      </div>
    </section>
  )}

  <!-- Cost Estimator -->
  <section class="content-section">
    <div class="wrap">
      <ROICalculator />
    </div>
  </section>

  <!-- FAQ -->
  <section class="content-section">
    <div class="wrap">
      <div class="section-label">FAQ</div>
      <div class="faq-list" id="faqList">
        {data.faq.map((item, i) => (
          <div class="faq-item reveal" data-faq={i}>
            <button class="faq-question">
              {item.q}
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">{item.a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {relatedServices.length > 0 && (
    <section class="content-section">
      <div class="wrap">
        <div class="section-label">Related services</div>
        <div class="related-grid">
          {relatedServices.map(s => (
            <a
              href={`/services/${s.id}`}
              class="related-card reveal"
              style={`--card-accent: ${s.data.accent}`}
            >
              <div class="related-card-top">
                <span class="related-card-icon">{s.data.icon}</span>
                <span class="related-card-arrow">↗</span>
              </div>
              <div class="related-card-title">{s.data.headline.replace(/\n/g, ' ')}</div>
              <span class="related-card-badge">{s.data.badge}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <div class="wrap">
    <div class="service-cta reveal">
      <div class="service-cta-glow"></div>
      <div class="cta-label">Ready to start?</div>
      <h2 class="cta-title">Let's build your {data.title.toLowerCase()}</h2>
      <p class="cta-sub">Free estimate within 24 hours. No commitment, no pressure — just a clear scope and honest pricing.</p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a href="/contact" class="btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          Get a free estimate
        </a>
        <a href="/services" class="btn-secondary">All services</a>
      </div>
    </div>
  </div>

  <script>
    // FAQ accordion
    document.querySelectorAll('.faq-item').forEach(item => {
      item.querySelector('.faq-question')?.addEventListener('click', () => {
        const isOpen = item.classList.contains('is-open');
        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('is-open'));
        if (!isOpen) item.classList.add('is-open');
      });
    });
  </script>
</Layout>
