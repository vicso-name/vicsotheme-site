
---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => !data.draft);

  return services.map(service => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const { data } = service;

const pageUrl = `https://vicsotheme.com/services/${service.id}`;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": data.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": data.title,
  "description": data.description,
  "url": pageUrl,
  "provider": {
    "@type": "Person",
    "name": "Viktor Sokoliuk",
    "url": "https://vicsotheme.com"
  }
};
---

<Layout title={data.title} description={data.description}>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <section class="hero">
    <div class="container">
      <div class="eyebrow">{data.category}</div>

      <h1 class="hero-title">{data.headline}</h1>

      <p class="hero-description">
        {data.description}
      </p>

      <div class="hero-actions">
        <a href="/contact" class="btn-primary">
          Discuss Your Product
        </a>

        <a href="#capabilities" class="btn-secondary">
          Explore Capabilities
        </a>
      </div>

      <div class="hero-grid">
        <div class="grid-card">
          <span>AI MVPs</span>
        </div>

        <div class="grid-card">
          <span>LLM Integrations</span>
        </div>

        <div class="grid-card">
          <span>Workflow Automation</span>
        </div>

        <div class="grid-card">
          <span>Scalable Systems</span>
        </div>
      </div>
    </div>
  </section>

  <section class="capabilities" id="capabilities">
    <div class="container">
      <div class="section-label">Capabilities</div>

      <h2 class="section-title">
        What I Actually Build
      </h2>

      <div class="capabilities-grid">
        {data.capabilities.map((item) => (
          <article class="capability-card">
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="principles">
    <div class="container narrow">
      <div class="section-label">Approach</div>

      <h2 class="section-title">
        Product-First AI Engineering
      </h2>

      <div class="principles-stack">
        {data.principles.map((item) => (
          <div class="principle-item">
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="stack">
    <div class="container">
      <div class="section-label">Technology</div>

      <h2 class="section-title">
        Infrastructure & Stack
      </h2>

      <div class="stack-list">
        {data.stack.map((tech) => (
          <div class="stack-item">{tech}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="process">
    <div class="container narrow">
      <div class="section-label">Engineering Process</div>

      <h2 class="section-title">
        From Idea To Production
      </h2>

      <div class="process-list">
        {data.process.map((item) => (
          <div class="process-item">
            <span class="step">{item.step}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="faq">
    <div class="container narrow">
      <div class="section-label">FAQ</div>

      <h2 class="section-title">
        Common Questions
      </h2>

      <div class="faq-list">
        {data.faq.map((item) => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container narrow">
      <div class="cta-box">
        <div class="section-label">AI Product Engineering</div>

        <h2>
          Building an AI-powered product?
        </h2>

        <p>
          Let’s discuss your product, workflows, and technical direction before writing unnecessary code.
        </p>

        <a href="/contact" class="btn-primary">
          Start a Conversation
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Uses global design tokens from Layout.astro:
     --bg, --bg-card, --bg-hover, --border, --border-hi,
     --text, --heading, --muted, --accent-d, --accent-b,
     --mono, --sans.
  */

  section {
    position: relative;
    z-index: 1;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .narrow {
    max-width: 860px;
  }

  /* ── Hero ── */
  .hero {
    padding: 80px 0 72px;
    overflow: hidden;
  }

  .eyebrow,
  .section-label {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
  }

  .eyebrow {
    color: var(--accent-b);
  }

  .hero-title {
    max-width: 860px;
    font-size: clamp(38px, 5.8vw, 68px);
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: var(--heading);
    margin-bottom: 22px;
  }

  .hero-description {
    max-width: 620px;
    font-size: 18px;
    line-height: 1.7;
    color: var(--muted);
    font-weight: 300;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 13px 24px;
    border-radius: 10px;
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.2s, background 0.2s, border-color 0.2s, transform 0.2s;
  }

  .btn-primary {
    background: var(--text);
    color: var(--bg);
    border: 1px solid transparent;
  }

  .btn-primary:hover {
    opacity: 0.86;
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    color: var(--text);
  }

  .btn-secondary:hover {
    background: var(--bg-card);
    border-color: var(--border-hi);
    transform: translateY(-1px);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .grid-card {
    min-height: 112px;
    display: flex;
    align-items: flex-end;
    padding: 22px;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg-card);
    overflow: hidden;
    position: relative;
    transition: border-color 0.25s, transform 0.25s, background 0.25s;
  }

  .grid-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(167,139,250,0.08), transparent 55%);
    opacity: 0;
    transition: opacity 0.25s;
  }

  .grid-card:hover {
    border-color: var(--border-hi);
    background: var(--bg-hover);
    transform: translateY(-2px);
  }

  .grid-card:hover::before {
    opacity: 1;
  }

  .grid-card span {
    position: relative;
    z-index: 1;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--muted-hi);
  }

  /* ── Shared sections ── */
  .capabilities,
  .principles,
  .stack,
  .process,
  .faq,
  .final-cta {
    padding: 0 0 96px;
  }

  .section-title {
    max-width: 760px;
    font-size: clamp(30px, 4vw, 48px);
    font-weight: 300;
    line-height: 1.14;
    letter-spacing: -0.035em;
    color: var(--heading);
    margin-bottom: 32px;
  }

  .capabilities-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .capability-card,
  .principle-item,
  .process-item,
  .faq-item,
  .cta-box {
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: border-color 0.25s, transform 0.25s, background 0.25s;
  }

  .capability-card {
    position: relative;
    padding: 32px;
    border-radius: 18px;
    overflow: hidden;
  }

  .capability-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 2px;
    background: var(--accent-d);
    opacity: 0.35;
  }

  .capability-card:hover,
  .principle-item:hover,
  .process-item:hover {
    border-color: var(--border-hi);
    background: var(--bg-hover);
    transform: translateY(-2px);
  }

  .capability-card h3,
  .principle-item h3,
  .process-item h3 {
    font-size: 18px;
    font-weight: 500;
    color: var(--heading);
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .capability-card p,
  .principle-item p,
  .process-item p,
  .faq-item p,
  .cta-box p {
    color: var(--muted);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.7;
  }

  /* ── Principles ── */
  .principles-stack {
    display: grid;
    gap: 16px;
  }

  .principle-item {
    padding: 30px 32px;
    border-radius: 18px;
  }

  /* ── Stack ── */
  .stack-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .stack-item {
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1;
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 8px 12px;
    color: var(--muted);
    background: var(--bg-card);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .stack-item:hover {
    border-color: var(--border-hi);
    color: var(--text);
    background: var(--bg-hover);
  }

  /* ── Process ── */
  .process-list {
    display: grid;
    gap: 16px;
  }

  .process-item {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 22px;
    padding: 28px 32px;
    border-radius: 18px;
  }

  .step {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg-hover);
    color: var(--accent-d);
    font-family: var(--mono);
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* ── FAQ ── */
  .faq-list {
    display: grid;
    gap: 12px;
  }

  .faq-item {
    border-radius: 16px;
    padding: 0;
    overflow: hidden;
  }

  .faq-item[open] {
    border-color: var(--border-hi);
    background: var(--bg-hover);
  }

  .faq-item summary {
    cursor: pointer;
    list-style: none;
    padding: 22px 24px;
    font-size: 16px;
    font-weight: 500;
    color: var(--heading);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: "+";
    font-family: var(--mono);
    color: var(--muted);
    transition: transform 0.2s, color 0.2s;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
    color: var(--text);
  }

  .faq-item p {
    padding: 0 24px 24px;
    margin: 0;
  }

  /* ── CTA ── */
  .cta-box {
    position: relative;
    padding: 56px 48px;
    border-radius: 20px;
    text-align: center;
    overflow: hidden;
  }

  .cta-box > * {
    position: relative;
    z-index: 1;
  }

  .cta-box h2 {
    max-width: 680px;
    margin: 0 auto 16px;
    font-size: clamp(30px, 4vw, 44px);
    font-weight: 300;
    line-height: 1.15;
    letter-spacing: -0.035em;
    color: var(--heading);
  }

  .cta-box p {
    max-width: 560px;
    margin: 0 auto 32px;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .capabilities-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .hero {
      padding: 64px 0 64px;
    }

    .capabilities,
    .principles,
    .stack,
    .process,
    .faq,
    .final-cta {
      padding-bottom: 72px;
    }
  }

  @media (max-width: 620px) {
    .container {
      padding: 0 20px;
    }

    .hero-grid,
    .capabilities-grid {
      grid-template-columns: 1fr;
    }

    .hero-title {
      font-size: clamp(36px, 11vw, 54px);
    }

    .hero-description {
      font-size: 16px;
    }

    .hero-actions {
      margin-bottom: 40px;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
    }

    .grid-card {
      min-height: 86px;
    }

    .process-item {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .capability-card,
    .principle-item,
    .process-item {
      padding: 26px 24px;
    }

    .cta-box {
      padding: 40px 24px;
    }
  }
</style>
