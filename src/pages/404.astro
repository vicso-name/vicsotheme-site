---
import Layout from '../layouts/Layout.astro';

const title = 'Page not found — VicsoTheme';
const description = 'The page you are looking for does not exist or has been moved.';
---

<Layout title={title} description={description} noindex={true}>
  <main class="not-found">
    <section class="not-found__inner">
      <p class="not-found__eyebrow">404</p>

      <h1 class="not-found__title">
        Page not found
      </h1>

      <p class="not-found__text">
        The page you are looking for does not exist, was moved, or is no longer available.
      </p>

      <div class="not-found__actions">
        <a href="/" class="not-found__primary">Go to homepage</a>
        <a href="/services/" class="not-found__secondary">View services</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .not-found {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 96px 24px;
  }

  .not-found__inner {
    width: min(720px, 100%);
    text-align: center;
  }

  .not-found__eyebrow {
    margin: 0 0 16px;
    font-size: 14px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted, #6b7280);
  }

  .not-found__title {
    margin: 0;
    font-size: clamp(48px, 8vw, 92px);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .not-found__text {
    margin: 24px auto 0;
    max-width: 520px;
    font-size: 18px;
    line-height: 1.7;
    color: var(--muted, #6b7280);
  }

  .not-found__actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 36px;
    flex-wrap: wrap;
  }

  .not-found__primary,
  .not-found__secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 20px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
  }

  .not-found__primary {
    background: #111827;
    color: #fff;
  }

  .not-found__secondary {
    border: 1px solid rgba(17, 24, 39, 0.14);
    color: #111827;
  }

  @media (max-width: 640px) {
    .not-found {
      padding: 72px 18px;
    }

    .not-found__actions {
      flex-direction: column;
    }

    .not-found__primary,
    .not-found__secondary {
      width: 100%;
    }
  }
</style>